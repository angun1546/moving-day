# 이삿날 프론트엔드 환경변수 — 실제 값은 .env(로컬)에 입력
# .env는 .gitignore에 포함되어 절대 커밋되지 않습니다. 이 파일에 실제 값을 적지 마세요.

# 백엔드 API 절대 URL — 다른 도메인의 백엔드를 쓸 때만 설정
# 가비아 단일 서버 배포는 Nginx가 같은 도메인에서 /api → :4000을 프록시하므로 비워둡니다.
# 로컬도 비워두면 vite proxy가 /api → http://localhost:4000 으로 연결합니다.
VITE_API_BASE=

# 카카오 간편 로그인 — 둘 다 있어야 로그인 페이지에 '카카오로 시작하기' 버튼 노출
# REST 키: 카카오 디벨로퍼스 > 내 애플리케이션 > 앱 키 > REST API 키
# 리다이렉트 URI: 백엔드 콜백 주소 (카카오 콘솔 '카카오 로그인 > Redirect URI'에 동일하게 등록)
#   로컬:  http://localhost:4000/api/auth/kakao/callback
#   운영:  https://themovingday.com/api/auth/kakao/callback
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback
