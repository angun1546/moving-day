# 이삿날 백엔드 환경변수 — 실제 값은 .env(로컬) 또는 Render Environment(배포)에 입력
# .env는 .gitignore에 포함되어 절대 커밋되지 않습니다. 이 파일에 실제 키를 적지 마세요.

# 데이터베이스 (로컬은 file:..., 배포는 Turso libsql URL)
DATABASE_URL=file:./prisma/dev.db
# 배포(Turso)에서만 필요 — Turso 대시보드에서 토큰 발급
DATABASE_AUTH_TOKEN=

# JWT 서명 키 — 운영에서는 길고 임의의 문자열 (openssl rand -hex 32 등)
JWT_SECRET=change-me-to-a-long-random-string

# 프론트엔드 CORS 화이트리스트 (콤마로 다중 도메인 허용)
FRONTEND_URL=http://localhost:5173

# Cloudinary (견적 신청 사진 업로드)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 포트 (Render는 자동 주입 — 비워두기)
# PORT=4000
