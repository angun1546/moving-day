# 이삿날 백엔드 환경변수 — 실제 값은 .env(로컬) 또는 서버 .env(가비아 g클라우드)에 입력
# .env는 .gitignore에 포함되어 절대 커밋되지 않습니다. 이 파일에 실제 키를 적지 마세요.

# 데이터베이스 — SQLite 파일 경로
# 로컬: file:./prisma/dev.db / 서버: file:/var/www/moving-day/backend/prisma/prod.db
DATABASE_URL=file:./prisma/dev.db

# 배포 환경 표시 — production이면 JWT_SECRET 누락 시 시작 거부
# NODE_ENV=production

# JWT 서명 키 — 운영에서는 길고 임의의 문자열 (openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string

# 관리자 이메일 — 이 이메일로 가입 시 role=admin 자동 부여. 코드에 두지 않고 여기에만(비공개)
ADMIN_EMAIL=

# 프론트엔드 CORS 화이트리스트 (콤마로 다중 도메인 허용)
FRONTEND_URL=http://localhost:5173

# Cloudinary (사진 업로드)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 솔라피(Solapi) SMS/카카오 알림톡
# 아래 3개만 있으면 SMS 실제 발송, 하나라도 없으면 mock(콘솔 로그만)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=01012345678
# 카카오 알림톡(선택) — 채널·템플릿 승인 후 입력. 설정 시 알림톡 우선·실패하면 SMS 자동 대체
SOLAPI_KAKAO_PF_ID=
SOLAPI_ALIMTALK_TEMPLATE_QUOTE=
SOLAPI_ALIMTALK_TEMPLATE_BID=
SOLAPI_ALIMTALK_TEMPLATE_AWARD=
SOLAPI_ALIMTALK_TEMPLATE_REJECT=
SOLAPI_ALIMTALK_TEMPLATE_STAGE=

# 포트 (Nginx 프록시 대상)
# PORT=4000
