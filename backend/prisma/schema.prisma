// Prisma 7 스키마 - 이사 플랫폼(Moving Day)
// 새 prisma-client 생성기 + SQLite 드라이버 어댑터 방식

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  // Prisma 7: url은 schema에 두지 않음 (prisma.config.ts의 datasource.url 사용)
  // 런타임 연결은 src/db.ts의 드라이버 어댑터(better-sqlite3)가 담당
  provider = "sqlite"
}

// 이사 견적 신청
model QuoteRequest {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  name       String // 신청자 이름
  phone      String // 연락처
  moveType   String // 이사 종류: 포장이사 / 반포장이사 / 일반이사 / 사무실이사
  fromRegion String // 출발지 (지역)
  toRegion   String // 도착지 (지역)
  moveDate   String? // 이사 예정일 (예: 2026-06-15)
  homeSize   String? // 주거 형태/평형 (예: 원룸, 20평대 등)
  memo       String? // 추가 요청사항
  photos     String? // 첨부 사진 경로 목록 (JSON 문자열)
  addons     String? // 부가 서비스 선택 (JSON: {cleaning, storage[], document[]})

  method    String // 견적 방식: 방문견적 / 사진견적 / 전화상담
  visitDate String? // 방문 희망 일시 (방문견적)
  callTime  String? // 통화 희망 시간대 (전화상담)

  status String @default("접수") // 접수 / 상담중 / 완료

  userEmail String? // 신청한 회원 이메일 (비회원은 null)
  stage     String? // 낙찰 후 진행 단계 (낙찰완료~이사완료, 미낙찰은 null)

  bids      Bid[] // 이 견적에 들어온 업체 입찰
  stageLogs StageLog[] // 진행 단계 변경 이력

  @@index([createdAt])
}

// 회원
model User {
  id        String   @id @default(cuid())
  username  String   @unique // 로그인 아이디 — 기존 회원은 이메일 값으로 백필
  email     String   @unique // 회원가입 정보·아이디 찾기·인증용 (로그인 수단 아님)
  password  String // bcrypt 해시
  name      String
  role      String   @default("customer") // customer | partner | admin
  birthDate String? // 생년월일 (YYYY-MM-DD) — 회원가입 시 API에서 필수 검증
  gender    String? // 성별: 남 / 여
  phone     String? // 전화번호
  verified  Boolean  @default(false) // 휴대폰 본인인증 여부 (추후 CI/DI 연동)
  createdAt DateTime @default(now())
}

// 업체(파트너) 입찰 — 견적 요청에 대한 제안
model Bid {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  bidderEmail String // 입찰한 파트너 이메일
  company     String // 업체명
  price       Int // 입찰가(원)
  message     String? // 고객에게 한마디
  eta         String? // 예상 소요시간

  status String @default("입찰") // 입찰 / 낙찰 / 거절

  @@index([quoteRequestId])
}

// 진행 단계 변경 이력 (택배식 타임라인 로그)
model StageLog {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  stage          String

  @@index([quoteRequestId])
}

// 고객 리뷰 — 업체별 평점 집계의 원천(이용 업체명 기준)
model Review {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String // 작성자 표시명(닉네임/마스킹된 실명)
  text        String
  rating      Int // 1~5
  moveType    String? // 이사 종류 태그
  company     String? // 이용 업체명 — 평점 집계 키
  authorEmail String? // 작성자 식별(본인 리뷰 동적 표시용)
  hidden      Boolean  @default(false) // 관리자 숨김
  reply       String? // 관리자 답변

  @@index([company])
  @@index([createdAt])
}

// 파트너 스토리 — 업체가 남기는 플랫폼 이용 후기
model PartnerStory {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  company     String // 업체명
  text        String
  rating      Int // 1~5
  authorEmail String? // 작성자 식별
  hidden      Boolean  @default(false) // 관리자 숨김
  reply       String? // 관리자 답변

  @@index([createdAt])
}

// Q&A 문의 — 고객(user)·파트너(partner) 질문 + 관리자 답변
model Qna {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  scope       String // user | partner
  name        String // 질문자 표시명
  q           String // 질문
  a           String? // 관리자 답변(없으면 미답변)
  authorEmail String? // 질문자 식별
  hidden      Boolean  @default(false) // 관리자 숨김

  @@index([scope, createdAt])
}

// 공지사항 — 관리자 작성, 고객·파트너 사이트 공유
model Notice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  title     String
  body      String

  @@index([createdAt])
}

// 파트너(업체) 프로필 — 로그인 파트너 이메일 1:1, 사진/자격증은 Cloudinary URL
model PartnerProfile {
  id         String   @id @default(cuid())
  email      String   @unique // 로그인 파트너 이메일
  company    String
  bizNo      String // 사업자등록번호
  ceo        String // 대표자명
  phone      String
  trucks     String? // 탑차 보유 대수
  intro      String? // 한 줄 소개
  regions    String   @default("[]") // 서비스 지역 JSON 배열
  profileImg String? // 프로필 사진 URL
  workPhotos String? // 업체·이사 사진 URL JSON 배열
  certs      String? // 자격증·서류 JSON 배열 [{url,name,isImage}]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 무빙 프로젝트 — 갤러리·포트폴리오 글(관리자 작성, 사진은 Cloudinary URL)
// kind로 갤러리/포트폴리오 구분 — 필드가 같아 모델 하나로 공용
model ProjectPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  kind      String // gallery | portfolio
  title     String
  excerpt   String // 요약/본문
  image     String? // 대표 사진 URL (Cloudinary)

  @@index([kind, createdAt])
}

// 무빙 브이로그 — 유튜브 영상 임베드(썸네일은 URL에서 자동 추출)
model Vlog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  title     String
  videoUrl  String // 유튜브 영상 URL

  @@index([createdAt])
}

// 불편사항 접수 — 사용자가 제출, 관리자가 상태·답변 처리
model Complaint {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String // 작성자 표시명
  contact     String // 연락처(전화/이메일)
  content     String // 불편사항 내용
  status      String   @default("접수") // 접수 | 처리중 | 완료
  reply       String? // 관리자 답변
  hidden      Boolean  @default(false) // 관리자 숨김 — 작성자 '내 불편사항'에서 가림
  authorEmail String? // 작성자 식별(회원)

  @@index([createdAt])
}

// 상담 신청 — 사용자가 제출(상담 도크), 관리자가 상태·메모 처리(전화·카톡 직접 응대)
model Consult {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String // 신청자 이름
  contact     String // 연락처(전화/이메일)
  moveType    String? // 이사 종류: 포장이사 / 반포장이사 / 일반이사 / 사무실이사
  content     String? // 상담 요청 내용
  status      String   @default("접수") // 접수 | 상담중 | 완료
  memo        String? // 관리자 내부 메모(고객 비노출)
  reply       String? // 관리자 답변(고객 전달 — 이메일 신청 시 해당 메일로 발송)
  hidden      Boolean  @default(false) // 관리자 숨김 — 작성자 '내 상담신청'에서 가림
  authorEmail String? // 작성자 식별(회원)

  @@index([createdAt])
}

// 팁 게시판 — 관리자 작성, 모든 사용자 열람(이사 팁 글)
model Tip {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  title     String
  content   String
  category  String? // 분류(선택)

  @@index([createdAt])
}

// 사용자 알림 — 서버 거래 이벤트(입찰·낙찰·거절·단계변경)에서 생성, 프론트가 폴링으로 조회
model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  toEmail   String // 수신자 이메일
  type      String // bid | award | reject | stage
  message   String
  link      String? // 클릭 시 이동할 프론트 경로
  read      Boolean  @default(false)

  @@index([toEmail, createdAt])
}
